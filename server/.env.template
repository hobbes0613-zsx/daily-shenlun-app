# 每日申论应用 - 环境变量配置
# 请复制此文件为 .env 并填写真实值

# ============================================================
# Supabase 数据库配置（必填）
# 获取方式：登录 https://supabase.com → Project Settings → API
# ============================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ============================================================
# Coze AI API密钥（必填）
# 获取方式：登录 https://www.coze.com → 头像 → API Tokens → Create Token
# ============================================================
COZE_API_KEY=pat_your-coze-api-key-here

# ============================================================
# 服务器配置（可选，Railway会自动设置）
# ============================================================
PORT=5000
NODE_ENV=production

# ============================================================
# 数据库连接（如果使用Drizzle ORM）
# ============================================================
# DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================================
# 其他配置
# ============================================================
# 日志级别：debug, info, warn, error
# LOG_LEVEL=info
